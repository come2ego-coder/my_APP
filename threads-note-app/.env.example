# Gemini API key used server-side only (never exposed to the browser).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model used for generation.
# GEMINI_MODEL=gemini-flash-latest

# Shared password required to use the app. Anyone without this password is
# redirected to /login. If unset, nobody can log in (fails closed).
APP_ACCESS_PASSWORD=

# Optional: caps total /api/generate calls per day across all visitors.
# Requires an Upstash Redis integration (Vercel Storage tab) connected to
# this project, which sets UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# automatically. Without those set, the daily limit is skipped entirely.
# DAILY_GENERATION_LIMIT=100
