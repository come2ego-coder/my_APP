# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Typefully API key, issued from Settings -> API on typefully.com
TYPEFULLY_API_KEY=

# Typefully Social Set ID that has your Threads account connected
TYPEFULLY_SOCIAL_SET_ID=

# Optional overrides
# ANTHROPIC_MODEL=claude-sonnet-5
# TYPEFULLY_API_BASE=https://api.typefully.com
# TYPEFULLY_PLATFORM_KEY=threads
