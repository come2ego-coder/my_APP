# Gemini API key used server-side only (never exposed to the browser).
# Get a free key at https://aistudio.google.com/apikey
# Required for automatic receipt reading. Without it, the app still works
# but you have to fill in the amount/category by hand.
GEMINI_API_KEY=

# Optional: override the model used for reading receipts. Must support
# image input. Unset defaults to gemini-flash-latest.
# GEMINI_MODEL=gemini-flash-latest

# Optional account login (sign up / log in so records follow you across
# devices). Without these, the app still works fully in local-only mode
# (data stays in the browser's localStorage).
#
# KV_REST_API_URL / KV_REST_API_TOKEN: set automatically when you connect
# an Upstash Redis integration from the Vercel Storage tab.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# AUTH_SECRET: any random string, used to sign login session cookies.
# AUTH_SECRET=
